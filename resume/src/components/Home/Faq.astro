---
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const strings = t(lang);
const faq = strings.faq;
---

<section id="faq" class="py-section px-4 bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 reveal">
      <span class="eyebrow mb-5">{faq.eyebrow}</span>
      <h2 class="mt-5 whitespace-pre-line font-display text-display-md font-black text-dark">
        {faq.title}
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {faq.items.map((item, index) => (
        <article class="reveal card-shell h-full" data-delay={String(index * 70)}>
          <div class="card-core h-full p-6">
            <h3 class="font-display text-lg font-bold text-dark">{item.question}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{item.answer}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
