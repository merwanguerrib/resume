---
import { Image } from 'astro:assets';
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';
import merwanPhoto from '../../assets/merwan-photo.jpg';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const strings = t(lang);
const { about } = strings;

const valueIcons: Record<string, string> = {
  lightning:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  shield:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v5c0 4.4-2.9 8.5-7 9.8C7.9 19.5 5 15.4 5 11V6l7-3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  chat:
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 12a7 7 0 01-7 7H8l-4 3v-5a7 7 0 117-7h2a7 7 0 017 7z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  'trend-up':
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 16l5-5 4 4 7-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8h6v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---

<section id="about" class="py-section px-4 bg-elevated">
  <div class="mx-auto max-w-6xl">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: photo -->
      <div
        class="reveal flex justify-center lg:justify-start order-2 lg:order-1"
      >
        <div class="relative">
          <!-- Outer shell -->
          <div class="card-shell w-[280px] md:w-[340px]">
            <div class="card-core overflow-hidden" style="height: 380px;">
              <Image
                src={merwanPhoto}
                alt="Merwan Guerrib"
                class="w-full h-full object-cover object-top"
                loading="lazy"
                decoding="async"
                widths={[280, 340, 680]}
                sizes="(min-width: 1024px) 340px, (min-width: 768px) 340px, 280px"
                format="webp"
              />
            </div>
          </div>

          <!-- Location badge -->
          <div
            class="absolute -bottom-4 left-1/2 -translate-x-1/2 card-shell shadow-card-hover whitespace-nowrap"
          >
            <div class="card-core px-4 py-2.5 flex items-center gap-2 text-sm">
              <span class="text-ink/75">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M12 22s7-5.8 7-12a7 7 0 10-14 0c0 6.2 7 12 7 12z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <circle
                    cx="12"
                    cy="10"
                    r="2.5"
                    stroke="currentColor"
                    stroke-width="1.6"></circle>
                </svg>
              </span>
              <span class="font-medium text-ink text-xs">Marseille, France</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Right: content -->
      <div class="flex flex-col gap-8 order-1 lg:order-2">
        <div class="reveal">
          <span class="eyebrow mb-5">{about.eyebrow}</span>
          <h2 class="font-display text-display-md font-black text-dark mt-5">
            {about.title}
          </h2>
        </div>

        <div class="reveal" data-delay="100">
          {
            about.bio
              .split('\n\n')
              .map((paragraph) => (
                <p class="text-muted leading-relaxed mb-4 last:mb-0">
                  {paragraph}
                </p>
              ))
          }
        </div>

        <!-- Values grid -->
        <div class="reveal grid grid-cols-2 gap-3" data-delay="200">
          {
            about.values.map((value) => (
              <div class="card-shell">
                <div class="card-core px-4 py-3 flex items-center gap-3">
                  <span class="text-ink/75" set:html={valueIcons[value.icon]} />
                  <span class="text-sm font-medium text-ink">
                    {value.label}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
