---
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';
import type { ServiceSlug } from '../../data/service-pages-data';
import {
  getServicePage,
  getServicePath,
  servicePageSlugs,
} from '../../data/service-pages-data';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const strings = t(lang);

interface ServiceCardMeta {
  slug: ServiceSlug;
  eyebrow: { en: string; fr: string };
  short: { en: string; fr: string };
  outcomes: { en: string[]; fr: string[] };
  cta: { en: string; fr: string };
}

const cardMetaBySlug: Record<ServiceSlug, ServiceCardMeta> = {
  website: {
    slug: 'website',
    eyebrow: {
      en: 'Pipeline Growth',
      fr: 'Acquisition & Conversion',
    },
    short: {
      en: 'Turn your site into a pipeline with sharper positioning, search-ready structure, and pages built to convert qualified demand.',
      fr: 'Construisez un website rapide et orienté conversion, avec un message clair, des fondations SEO solides et une structure qui transforme le trafic en leads qualifiés.',
    },
    outcomes: {
      en: [
        'Offer and messaging clarity',
        'Conversion UX and page architecture',
        'Technical SEO and schema foundations',
        'Analytics-ready website delivery',
      ],
      fr: [
        'Développement website',
        'Design UI/UX',
        'Contenu product marketing',
        'Structure SEO/GEO',
      ],
    },
    cta: {
      en: 'Explore website growth service',
      fr: 'Voir la page service website',
    },
  },
  app: {
    slug: 'app',
    eyebrow: {
      en: 'Product Velocity',
      fr: 'Delivery Produit',
    },
    short: {
      en: 'Ship product faster with a senior full-stack partner who can scope, build, and release features without stacking technical risk.',
      fr: 'Livrez des features d\'applications web full-stack avec une architecture stable, une auth sécurisée et une delivery prévisible de la discovery à la production.',
    },
    outcomes: {
      en: [
        'Feature scoping with technical guardrails',
        'Frontend + backend implementation',
        'API, data model, and auth alignment',
      ],
      fr: [
        'Support product management',
        'Delivery frontend + backend',
        'Alignement API et modèle de données',
      ],
    },
    cta: {
      en: 'Explore app delivery service',
      fr: 'Voir la page service app',
    },
  },
  'ai-automation': {
    slug: 'ai-automation',
    eyebrow: {
      en: 'Operational AI',
      fr: 'Opérations IA',
    },
    short: {
      en: 'Automate repetitive workflows with AI systems connected to your stack so your team saves time and executes with fewer handoffs.',
      fr: 'Automatisez les workflows répétitifs avec des systèmes IA connectés à votre stack, pour faire gagner du temps à votre équipe et accélérer les délais de réponse.',
    },
    outcomes: {
      en: [
        'AI integrations tied to business workflows',
        'Lead qualification and support triage automation',
        'Guardrails for quality and reliability',
      ],
      fr: [
        'Intégration IA',
        'Automatisation qualification leads',
        'Accélération opérations marketing',
      ],
    },
    cta: {
      en: 'Explore AI automation service',
      fr: 'Voir la page automatisation IA',
    },
  },
  n8n: {
    slug: 'n8n',
    eyebrow: {
      en: 'Workflow Reliability',
      fr: 'Backbone Workflow',
    },
    short: {
      en: 'Build reliable n8n workflows for CRM sync, routing, alerts, and cross-tool orchestration with proper monitoring and ownership.',
      fr: 'Concevez des workflows n8n robustes pour la sync CRM, le routing, les alertes et l\'orchestration cross-tools avec ownership clair et monitoring fiable.',
    },
    outcomes: {
      en: [
        'n8n architecture standards and naming',
        'Retries, fallbacks, and failure visibility',
        'Automation stability at scale',
      ],
      fr: [
        'Standards d\'architecture n8n',
        'Gestion des retries et erreurs',
        'Fiabilité opérationnelle à l\'échelle',
      ],
    },
    cta: {
      en: 'Explore n8n integration service',
      fr: 'Voir la page service n8n',
    },
  },
};

const orderedSlugs: ServiceSlug[] = ['website', 'app', 'ai-automation', 'n8n'];
const cards = orderedSlugs.map((slug) => {
  const page = getServicePage(slug);
  const meta = cardMetaBySlug[slug];
  return {
    slug,
    label: page.label[lang],
    href: getServicePath(slug, lang),
    eyebrow: meta.eyebrow[lang],
    short: meta.short[lang],
    outcomes: meta.outcomes[lang],
    cta: meta.cta[lang],
  };
});
---

<section id="services" class="pt-12 md:pt-16 pb-section px-4 overflow-hidden bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14 reveal">
      <span class="eyebrow mb-5">{strings.services.eyebrow}</span>
      <h2 class="mt-5 whitespace-pre-line font-display text-display-lg font-black text-dark">
        {strings.services.title}
      </h2>
      <p class="mt-5 max-w-3xl text-base leading-relaxed text-muted md:text-lg">
        {lang === 'fr'
          ? 'Chaque carte ci-dessous correspond à une page service dédiée, avec une offre claire, une FAQ ciblée et un parcours de conversion cohérent.'
          : 'Each card leads to a dedicated service page with offer scope, targeted FAQ, and a clear next step.'}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {cards.map((card, index) => (
        <a
          href={card.href}
          class="reveal card-shell group service-card block focus:outline-none focus-visible:ring-2 focus-visible:ring-dark/20"
          data-delay={String(index * 80)}
        >
          <div class="card-core flex h-full flex-col p-7 md:p-8">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted">{card.eyebrow}</span>
            <h3 class="service-title mt-3">{card.label}</h3>
            <p class="service-copy mt-3">{card.short}</p>

            <ul class="mt-5 grid gap-2">
              {card.outcomes.map((item) => (
                <li class="service-list-item">{item}</li>
              ))}
            </ul>

            <span class="service-cta mt-6 inline-flex items-center gap-2 text-sm font-semibold text-dark">
              {card.cta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 11L11 3M11 3H5.5M11 3V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 reveal" data-delay="380">
      <div class="card-shell">
        <div class="card-core p-5 md:p-6">
          <p class="text-sm font-medium text-muted">
            {lang === 'fr'
              ? 'Besoin d\'un diagnostic rapide avant de choisir le bon service ?'
              : 'Not sure where to start? Get a fast diagnostic and prioritized plan.'}
          </p>
          <div class="mt-4 flex flex-wrap gap-2.5">
            <a href={lang === 'fr' ? '/fr/#lead-magnet' : '/#lead-magnet'} class="btn-primary text-sm px-5 py-3">
              {lang === 'fr' ? 'Recevoir l\'audit gratuit' : 'Get the free diagnostic'}
            </a>
            <a href={lang === 'fr' ? '/fr/#contact' : '/#contact'} class="btn-ghost text-sm px-5 py-3">
              {lang === 'fr' ? 'Parler de votre projet' : 'Discuss your project scope'}
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 reveal" data-delay="440">
      <div class="flex flex-wrap gap-2">
        {servicePageSlugs.map((slug) => (
          <a
            href={getServicePath(slug, lang)}
            class="inline-flex items-center rounded-full border border-black/10 bg-canvas px-4 py-2 text-sm font-medium text-dark transition-colors duration-200 hover:bg-white"
          >
            {getServicePage(slug).label[lang]}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .service-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.45rem, 0.65vw + 1.2rem, 1.82rem);
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #1f1e1b;
  }

  .service-copy {
    font-size: clamp(1rem, 0.3vw + 0.9rem, 1.08rem);
    line-height: 1.6;
    color: #6d6962;
  }

  .service-list-item {
    position: relative;
    padding-left: 1rem;
    color: #1f1e1b;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .service-list-item::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    left: 0;
    width: 0.36rem;
    height: 0.36rem;
    border-radius: 9999px;
    background: rgba(12, 12, 10, 0.75);
    box-shadow: 0 0 0 4px rgba(12, 12, 10, 0.08);
  }

  .service-card {
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .service-card:hover {
    transform: translateY(-4px);
  }

  .service-card .card-core {
    transition: box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .service-card:hover .card-core {
    box-shadow: 0 2px 4px rgba(12, 12, 10, 0.06), 0 14px 36px rgba(12, 12, 10, 0.1);
  }

  .service-card:hover .service-cta {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
