---
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const strings = t(lang);

const typewriterWords =
  lang === 'en'
    ? [
        'a website',
        'an app',
        'an AI workflow',
        'an n8n stack',
        'a product',
        'Just dev it.',
      ]
    : [
        'un site web',
        'une app',
        'un workflow IA',
        'une stack n8n',
        'un produit',
        'Just dev it.',
      ];

const offerPanel =
  lang === 'en'
    ? {
        label: 'Offer format',
        heading: 'Growth build sprint',
        summary:
          'A focused sprint to ship a conversion-ready website, app module, or AI automation with clear priorities.',
        includesTitle: 'Included in the sprint',
        includes: [
          'Strategy workshop and scope lock',
          'Design + fullstack implementation',
          'QA, launch, and actionable handover',
        ],
        terms: [
          { label: 'Kickoff', value: 'within 7 days' },
          { label: 'Delivery window', value: '3 to 6 weeks' },
          { label: 'Replies', value: '< 24h on weekdays' },
        ],
      }
    : {
        label: "Format d'offre",
        heading: 'Sprint de build & lancement',
        summary:
          'Un sprint ciblé pour livrer un site web orienté conversion, un module d’application ou une automatisation IA avec des priorités claires.',
        includesTitle: 'Inclus dans le sprint',
        includes: [
          'Atelier de cadrage stratégique',
          'Conception UX/UI + développement full-stack',
          'QA, mise en production et documentation actionnable',
        ],
        terms: [
          { label: 'Démarrage', value: 'sous 7 jours' },
          { label: 'Fenêtre de livraison', value: '3 à 6 semaines' },
          { label: 'Temps de réponse', value: '< 24 h en semaine' },
        ],
      };
---

<section
  id="hero"
  class="relative min-h-[100dvh] flex flex-col justify-center pt-28 pb-24 px-4 overflow-hidden"
>
  <!-- Background radials -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute top-0 right-0 w-[800px] h-[800px] rounded-full opacity-40"
      style="background: radial-gradient(circle at 75% 15%, #EDE9E0, transparent 55%)"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[600px] h-[600px] rounded-full opacity-25"
      style="background: radial-gradient(circle at 20% 85%, #E4DFD4, transparent 55%)"
    >
    </div>
  </div>

  <div class="relative mx-auto w-full max-w-6xl">
    <div
      class="grid lg:grid-cols-[minmax(0,1.16fr)_minmax(320px,0.84fr)] gap-10 lg:gap-10 items-center"
    >
      <!-- Left: Text content -->
      <div class="flex flex-col gap-10 min-w-0 overflow-hidden">
        <!-- Eyebrow -->
        <div class="animate-fade-up">
          <span class="eyebrow">
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
              ></span>
            </span>
            {strings.hero.available}
          </span>
        </div>

        <!-- Typewriter + tagline -->
        <div class="animate-fade-up-1 flex flex-col gap-3">
          <!-- Rotating word — clipped to column width, never wraps -->
          <div
            class="flex items-baseline gap-1 overflow-visible pb-1 w-full"
          >
            <h1
              id="typewriter-word"
              class="font-display text-[clamp(1.95rem,5.35vw,4rem)] font-black leading-[1.02] tracking-[-0.03em] transition-colors duration-300 whitespace-nowrap min-w-0 block"
              style="color: rgba(155,151,145,0.5)"
            >
            </h1>
            <span
              id="typewriter-cursor"
              class="font-display text-[clamp(1.95rem,5.35vw,4rem)] font-black text-muted/40 leading-[1.02] select-none shrink-0"
              >_</span
            >
          </div>
        </div>

        <!-- Subtitle -->
        <div class="animate-fade-up-2">
          <p
            class="text-xl md:text-2xl text-muted font-sans leading-relaxed max-w-lg whitespace-pre-line"
          >
            {strings.hero.subtitle}
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 animate-fade-up-3">
          <a href="#lead-magnet" class="group btn-primary text-base px-7 py-3.5">
            {strings.hero.cta_primary}
            <span class="btn-icon">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 11L11 3M11 3H5M11 3V9"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
          <a href="#work" class="btn-ghost text-base px-7 py-3.5">
            {strings.hero.cta_secondary}
          </a>
        </div>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-8 animate-fade-up-4">
          {
            strings.stats.map((stat) => (
              <div class="flex flex-col gap-1">
                <span class="font-display text-3xl font-black text-dark">
                  {stat.value}
                </span>
                <span class="text-xs text-muted font-medium uppercase tracking-widest">
                  {stat.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: Offer visual -->
      <div
        class="relative flex justify-center lg:justify-end animate-fade-up-2"
      >
        <div class="card-shell w-[320px] md:w-[390px]">
          <div class="card-core p-6 md:p-7 offer-core">
            <div class="offer-label">{offerPanel.label}</div>
            <h2
              class="mt-3 font-display text-[1.6rem] leading-tight tracking-[-0.02em] text-dark"
            >
              {offerPanel.heading}
            </h2>
            <p class="offer-summary">{offerPanel.summary}</p>

            <div class="offer-includes">
              <p class="offer-block-title">{offerPanel.includesTitle}</p>
              <ul class="offer-list">
                {offerPanel.includes.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            <div class="offer-terms">
              {
                offerPanel.terms.map((term) => (
                  <div class="offer-term">
                    <p class="offer-term-label">{term.label}</p>
                    <p class="offer-term-value">{term.value}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  #typewriter-cursor {
    animation: blink 0.9s step-end infinite;
  }

  .offer-core {
    position: relative;
    overflow: hidden;
  }

  .offer-core::after {
    content: '';
    position: absolute;
    right: -18%;
    bottom: -30%;
    width: 210px;
    height: 210px;
    border-radius: 9999px;
    background: radial-gradient(
      circle,
      rgba(12, 12, 10, 0.06) 0%,
      rgba(12, 12, 10, 0) 70%
    );
    pointer-events: none;
  }

  .offer-label {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    background: rgba(12, 12, 10, 0.05);
    color: #6d6962;
    padding: 6px 10px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .offer-summary {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.55;
    color: #6d6962;
  }

  .offer-includes {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid rgba(12, 12, 10, 0.08);
  }

  .offer-block-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #9b9791;
  }

  .offer-list {
    margin-top: 10px;
    display: grid;
    gap: 8px;
    font-size: 13px;
    line-height: 1.4;
    color: #1f1e1b;
    list-style: none;
    padding: 0;
  }

  .offer-list li {
    position: relative;
    padding-left: 16px;
  }

  .offer-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: #0c0c0a;
    box-shadow: 0 0 0 4px rgba(12, 12, 10, 0.08);
  }

  .offer-terms {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .offer-term {
    display: grid;
    grid-template-rows: auto 1fr;
    align-content: start;
    border-radius: 0.85rem;
    border: 1px solid rgba(12, 12, 10, 0.08);
    background: rgba(255, 255, 255, 0.72);
    padding: 9px 10px;
    min-height: 100px;
  }

  .offer-term-label {
    font-size: 10px;
    line-height: 1.35;
    min-height: 2.7em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9b9791;
    font-weight: 600;
  }

  .offer-term-value {
    margin-top: 6px;
    font-size: 13px;
    font-weight: 600;
    color: #1f1e1b;
    line-height: 1.28;
    min-height: 2.6em;
    text-wrap: pretty;
  }

  @media (max-width: 1023px) {
    .offer-terms {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 639px) {
    .offer-term-value {
      font-size: 12px;
    }
  }
</style>

<script define:vars={{ typewriterWords }}>
  (function () {
    const wordEl = document.getElementById('typewriter-word');
    if (!wordEl) return;

    const CONCLUSION_INDEX = typewriterWords.length - 1;
    const COLOR_MUTED = 'rgba(155,151,145,0.5)';
    const COLOR_DARK = '#0C0C0A';

    let wordIndex = 0;
    let charIndex = 0;
    let deleting = false;
    const TYPING_SPEED = 80;
    const DELETING_SPEED = 45;
    const PAUSE_DURATION = 1800;
    const CONCLUSION_PAUSE = 4000;

    function type() {
      const current = typewriterWords[wordIndex];
      const isConclusion = wordIndex === CONCLUSION_INDEX;

      if (!deleting) {
        wordEl.textContent = current.slice(0, charIndex + 1);
        wordEl.style.color = isConclusion ? COLOR_DARK : COLOR_MUTED;
        charIndex++;
        if (charIndex === current.length) {
          deleting = true;
          setTimeout(type, isConclusion ? CONCLUSION_PAUSE : PAUSE_DURATION);
          return;
        }
        setTimeout(type, TYPING_SPEED);
      } else {
        wordEl.textContent = current.slice(0, charIndex - 1);
        charIndex--;
        if (charIndex === 0) {
          deleting = false;
          wordIndex = (wordIndex + 1) % typewriterWords.length;
          wordEl.style.color = COLOR_MUTED;
          setTimeout(type, 300);
          return;
        }
        setTimeout(type, DELETING_SPEED);
      }
    }

    // Start after hero animations settle
    setTimeout(type, 900);
  })();
</script>
