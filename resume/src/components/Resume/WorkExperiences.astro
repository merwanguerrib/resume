---
import { workExperienceData } from '../../data/work-experience-data';

const { list } = workExperienceData;
const formatDate = (date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
  });
---
<section class="rounded-3xl border border-line/80 bg-surface/90 p-6 shadow-soft backdrop-blur transition duration-300 motion-safe:animate-fade-up sm:p-8">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-ink">Work Experience</h2>
    <span class="text-xs uppercase tracking-widest text-muted">2026-ready</span>
  </div>
  <div class="space-y-6">
    {list.map((experience) => (
      <div class="group flex flex-col gap-4 rounded-2xl border border-transparent p-4 sm:flex-row sm:items-start">
        <div
          class="h-12 w-12 flex-shrink-0 rounded-2xl bg-cover bg-center shadow-soft ring-1 ring-primary/10"
          style={`background-image: url(${experience.logo});`}
        ></div>
        <div class="w-full space-y-4">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-2">
              <div class="text-base font-semibold text-ink">
                {experience.position}
              </div>
              <div class="flex flex-wrap gap-4 text-sm text-muted">
                <div class="flex items-center gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                  <span>{experience.company}</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    ></path>
                  </svg>
                  <span>{experience.city}</span>
                </div>
              </div>
            </div>
            <div class="space-y-2 text-sm sm:text-right">
              <div class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                Full time
              </div>
              <div class="flex items-center gap-2 text-muted sm:justify-end">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <span>
                  {formatDate(experience.startDate)} –
                  {experience.endDate ? formatDate(experience.endDate) : 'Present'}
                </span>
              </div>
            </div>
          </div>
          {experience.description ? (
            <p class="text-sm leading-relaxed text-muted">
              {experience.description}
            </p>
          ) : null}
          {experience.projects ? (
            <ul class="list-disc space-y-1 pl-5 text-sm text-muted">
              {experience.projects.map((project) =>
                project.description.map((description) => (
                  <li>{description}</li>
                ))
              )}
            </ul>
          ) : null}
          <div class="border-b border-line/80"></div>
        </div>
      </div>
    ))}
  </div>
</section>
