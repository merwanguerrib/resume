---
import { bioData } from '../../data/bio-data';

const data = bioData;
---
<div class="space-y-4">
  <div class="space-y-2">
    <h2 class="text-lg font-semibold text-ink">About me</h2>
    <p class="text-sm font-medium text-muted">{data.catchPhrase}</p>
  </div>
  <p class="text-sm leading-relaxed text-ink/90">{data.bio}</p>
  <div class="flex flex-col gap-4">
    {data.qualities && (
      <ul class="flex flex-wrap gap-x-4 gap-y-1 text-sm font-medium text-primary">
        {data.qualities.map((quality, index) => (
          <li key={index}>{quality}</li>
        ))}
      </ul>
    )}
    <ul class="flex flex-wrap gap-3">
      <li>
        <a
          href="https://www.linkedin.com/in/merwanguerrib/"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-line/80 bg-surface text-primary transition duration-300 hover:border-primary/40 hover:text-primary-dark"
        >
          <i class="bx bxl-linkedin-square text-2xl"></i>
        </a>
      </li>
      <li>
        <a
          href="https://github.com/merwanguerrib"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-line/80 bg-surface text-primary transition duration-300 hover:border-primary/40 hover:text-primary-dark"
        >
          <i class="bx bxl-github text-2xl"></i>
        </a>
      </li>
      <li>
        <span class="inline-flex items-center rounded-full border border-line/80 bg-panel/40 px-4 py-2 text-xs font-medium text-muted">
          merwanguerrib@gmail.com
        </span>
      </li>
    </ul>
  </div>
  <div class="border-t border-line/80"></div>
</div>
