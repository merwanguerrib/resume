---
import '../styles/global.css';
import type { Lang } from '../data/site-strings';
import {
  getServicePage,
  getServicePath,
  servicePageSlugs,
  type ServiceSlug,
} from '../data/service-pages-data';

interface FaqItem {
  question: string;
  answer: string;
}

interface BreadcrumbTrailItem {
  name: string;
  path: string;
}

type SchemaPageType = 'home' | 'service' | 'notFound' | 'generic';

interface Props {
  title?: string;
  description?: string;
  faqItems?: FaqItem[];
  lang?: Lang;
  alternateEnPath?: string;
  alternateFrPath?: string;
  xDefaultPath?: string;
  schemaPageType?: SchemaPageType;
  serviceSchemaName?: string;
  serviceSchemaDescription?: string;
  breadcrumbTrail?: BreadcrumbTrailItem[];
}

const {
  title = 'Just Dev It Agency | Websites, Apps & AI Automation',
  description,
  faqItems = [],
  lang = 'en',
  alternateEnPath,
  alternateFrPath,
  xDefaultPath,
  schemaPageType = 'generic',
  serviceSchemaName,
  serviceSchemaDescription,
  breadcrumbTrail = [],
} = Astro.props;

const defaultDescription =
  lang === 'fr'
    ? 'Nous concevons des websites orientés conversion, des applications full-stack et des workflows d\'automatisation IA avec n8n ou des outils no-code. Basés à Marseille, nous accompagnons des clients partout.'
    : 'We design and build conversion-focused websites, full-stack apps, and AI automation systems with n8n and modern no-code tooling. Based in Marseille, serving clients worldwide.';

const pageDescription = description ?? defaultDescription;

const siteUrl = 'https://justdevit.agency';
const canonicalPath = Astro.url?.pathname ?? (lang === 'fr' ? '/fr/' : '/');
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const toAbsoluteUrl = (path: string) =>
  path.startsWith('http://') || path.startsWith('https://')
    ? path
    : new URL(path.startsWith('/') ? path : `/${path}`, siteUrl).toString();
const enUrl = toAbsoluteUrl(alternateEnPath ?? '/');
const frUrl = toAbsoluteUrl(alternateFrPath ?? '/fr/');
const xDefaultUrl = toAbsoluteUrl(xDefaultPath ?? alternateEnPath ?? '/');
const logoImage = new URL('/merwan-photo.png', siteUrl).toString();
const ogImagePath = lang === 'fr' ? '/justdevit_fr.png' : '/justdevit_en.png';
const ogImage = new URL(ogImagePath, siteUrl).toString();
const ogImageWidth = lang === 'fr' ? '1521' : '1408';
const ogImageHeight = lang === 'fr' ? '704' : '736';
const ogImageAlt =
  lang === 'fr'
    ? 'Aperçu de la page d’accueil Just dev it en français'
    : 'Preview of the Just dev it English homepage';
const robotsContent =
  schemaPageType === 'notFound'
    ? 'noindex,nofollow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'
    : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
const websiteId = `${siteUrl}#website`;
const organizationId = `${siteUrl}#organization`;
const personId = `${siteUrl}#person`;
const professionalServiceId = `${siteUrl}#professional-service`;
const webPageId = `${canonicalUrl}#webpage`;
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const faqId = `${canonicalUrl}#faq`;
const currentServiceId = `${canonicalUrl}#service`;
const inLanguage = lang === 'fr' ? 'fr-FR' : 'en-US';
const alternateOgLocale = lang === 'fr' ? 'en_US' : 'fr_FR';
const marseilleLat = 43.2965;
const marseilleLng = 5.3698;
const contactUrl = toAbsoluteUrl(lang === 'fr' ? '/fr/#contact' : '/#contact');
const isServiceSlug = (value: string): value is ServiceSlug =>
  servicePageSlugs.includes(value as ServiceSlug);
const servicePathMatch = canonicalPath.match(/^\/(?:fr\/)?services\/([^/]+)\/?$/);
const currentServiceSlug =
  servicePathMatch && isServiceSlug(servicePathMatch[1]) ? servicePathMatch[1] : null;

const serviceCatalogEntries = servicePageSlugs.map((slug) => {
  const page = getServicePage(slug);
  const localizedPath = getServicePath(slug, lang);
  const localizedUrl = toAbsoluteUrl(localizedPath);
  const alternatePath = getServicePath(slug, lang === 'fr' ? 'en' : 'fr');
  const alternateUrl = toAbsoluteUrl(alternatePath);
  return {
    slug,
    name: page.label[lang],
    headline: page.h1[lang],
    description: page.seoDescription[lang],
    url: localizedUrl,
    alternateUrl,
    id: `${localizedUrl}#service`,
  };
});
const serviceCatalogBySlug = new Map(serviceCatalogEntries.map((entry) => [entry.slug, entry]));
const currentServiceEntry =
  currentServiceSlug ? (serviceCatalogBySlug.get(currentServiceSlug) ?? null) : null;

const offeredServices =
  serviceCatalogEntries.map((entry) => entry.name);

const serviceCatalogGroups =
  lang === 'fr'
    ? [
        {
          name: 'Websites orientes conversion et applications full-stack',
          slugs: ['website', 'app'],
        },
        {
          name: 'Automatisation IA et workflows n8n',
          slugs: ['ai-automation', 'n8n'],
        },
      ]
    : [
        {
          name: 'Conversion websites and product engineering',
          slugs: ['website', 'app'],
        },
        {
          name: 'AI automation and n8n workflow systems',
          slugs: ['ai-automation', 'n8n'],
        },
      ];

const defaultBreadcrumbTrail: BreadcrumbTrailItem[] = [
  {
    name: lang === 'fr' ? 'Accueil' : 'Home',
    path: lang === 'fr' ? '/fr/' : '/',
  },
];

const resolvedBreadcrumbTrail =
  breadcrumbTrail.length > 0 ? breadcrumbTrail : defaultBreadcrumbTrail;

const breadcrumbItems = resolvedBreadcrumbTrail.map((entry, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: entry.name,
  item: toAbsoluteUrl(entry.path),
}));

const languageSchema = [
  {
    '@type': 'Language',
    '@id': `${siteUrl}#lang-en`,
    name: 'English',
    alternateName: 'en',
  },
  {
    '@type': 'Language',
    '@id': `${siteUrl}#lang-fr`,
    name: 'French',
    alternateName: 'fr',
  },
];

const languageRefs = languageSchema.map((language) => ({ '@id': language['@id'] }));
const primaryServiceId = `${siteUrl}#service-catalog`;
const personSameAs = [
  'https://www.linkedin.com/in/merwanguerrib',
  'https://github.com/merwanguerrib',
];
const organizationSameAs = [
  'https://www.linkedin.com/company/justdevitagency/',
];

const personSchema = {
  '@type': 'Person',
  '@id': personId,
  name: 'Merwan Guerrib',
  jobTitle:
    lang === 'en'
      ? 'Founder and technical director'
      : 'Fondateur et directeur technique',
  url: siteUrl,
  image: logoImage,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Marseille',
    addressRegion: 'Provence-Alpes-Côte d\'Azur',
    addressCountry: 'FR',
  },
  sameAs: personSameAs,
  worksFor: {
    '@id': organizationId,
  },
  knowsLanguage: languageRefs,
  knowsAbout: offeredServices,
};

const organizationSchema = {
  '@type': 'Organization',
  '@id': organizationId,
  name: 'Just Dev It Agency',
  url: siteUrl,
  description:
    lang === 'fr'
      ? 'Agence web spécialisée dans les sites orientés conversion, les applications full-stack et l’automatisation IA.'
      : 'Agency focused on conversion-led websites, full-stack applications, and AI automation.',
  logo: {
    '@type': 'ImageObject',
    url: logoImage,
  },
  sameAs: organizationSameAs,
  knowsLanguage: languageRefs,
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'merwanguerrib@gmail.com',
      areaServed: 'Worldwide',
      availableLanguage: languageRefs,
    },
  ],
};

const professionalServiceSchema = {
  '@type': 'ProfessionalService',
  '@id': professionalServiceId,
  name: 'Just Dev It Agency',
  url: siteUrl,
  image: logoImage,
  description: pageDescription,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Marseille',
    addressRegion: 'Provence-Alpes-Côte d\'Azur',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: marseilleLat,
    longitude: marseilleLng,
  },
  areaServed: 'Worldwide',
  founder: {
    '@id': personId,
  },
  parentOrganization: {
    '@id': organizationId,
  },
};

const primaryServiceSchema = {
  '@type': 'Service',
  '@id': primaryServiceId,
  name:
    lang === 'en'
      ? 'Website, app, and AI automation services'
      : 'Services website, app et automatisation IA',
  description: pageDescription,
  provider: {
    '@id': organizationId,
  },
  areaServed: 'Worldwide',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: lang === 'fr' ? 'Catalogue de services' : 'Service catalog',
    itemListElement: serviceCatalogGroups.map((group) => ({
      '@type': 'OfferCatalog',
      name: group.name,
      itemListElement: group.slugs
        .map((groupSlug) => serviceCatalogBySlug.get(groupSlug as ServiceSlug))
        .filter(Boolean)
        .map((entry) => ({
          '@type': 'Offer',
          url: entry.url,
          itemOffered: {
            '@id': entry.id,
          },
        })),
    })),
  },
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: contactUrl,
    availableLanguage: languageRefs,
  },
};

const currentServiceSchema =
  schemaPageType === 'service'
    ? {
        '@type': 'Service',
        '@id': currentServiceId,
        name: serviceSchemaName ?? currentServiceEntry?.headline ?? title,
        serviceType: currentServiceEntry?.name,
        description: serviceSchemaDescription ?? currentServiceEntry?.description ?? pageDescription,
        url: canonicalUrl,
        provider: {
          '@id': organizationId,
        },
        areaServed: 'Worldwide',
        availableChannel: {
          '@type': 'ServiceChannel',
          serviceUrl: contactUrl,
          availableLanguage: languageRefs,
        },
        isRelatedTo: {
          '@id': primaryServiceId,
        },
      }
    : null;

const webPageAbout = [
  { '@id': organizationId },
  { '@id': professionalServiceId },
  ...(schemaPageType === 'home' ? [{ '@id': primaryServiceId }] : []),
  ...(currentServiceSchema ? [{ '@id': currentServiceId }] : []),
];

const webPageSchema = {
  '@type': 'WebPage',
  '@id': webPageId,
  url: canonicalUrl,
  name: title,
  description: pageDescription,
  inLanguage,
  isPartOf: {
    '@id': websiteId,
  },
  mainEntity:
    schemaPageType === 'service'
      ? {
          '@id': currentServiceId,
        }
      : schemaPageType === 'home'
        ? {
            '@id': primaryServiceId,
          }
        : {
            '@id': organizationId,
          },
  about: webPageAbout,
  breadcrumb: {
    '@id': breadcrumbId,
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImage,
  },
};

const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  '@id': breadcrumbId,
  itemListElement: breadcrumbItems,
};

const faqSchema =
  faqItems.length > 0
    ? {
        '@type': 'FAQPage',
        '@id': faqId,
        isPartOf: {
          '@id': webPageId,
        },
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null;

const websiteSchema = {
  '@type': 'WebSite',
  '@id': websiteId,
  name: 'Just Dev It Agency',
  url: siteUrl,
  inLanguage: languageRefs,
  publisher: {
    '@id': organizationId,
  },
};

const structuredServicesSchema = serviceCatalogEntries.map((entry) => ({
  '@type': 'Service',
  '@id': entry.id,
  name: entry.headline,
  serviceType: entry.name,
  description: entry.description,
  url: entry.url,
  provider: {
    '@id': organizationId,
  },
  areaServed: 'Worldwide',
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: contactUrl,
    availableLanguage: languageRefs,
  },
  isRelatedTo: {
    '@id': primaryServiceId,
  },
}));

const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    organizationSchema,
    personSchema,
    professionalServiceSchema,
    websiteSchema,
    webPageSchema,
    breadcrumbSchema,
    ...(schemaPageType === 'home' ? [primaryServiceSchema, ...structuredServicesSchema] : []),
    currentServiceSchema,
    ...languageSchema,
    faqSchema,
  ].filter(Boolean),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F9F8F5" />
    <meta name="description" content={pageDescription} />
    <meta name="google-site-verification" content="vpjLfldnzKKjMOKbh1BBYPg_fC3ebiLmWGuwVspW1Mk" />
    <meta http-equiv="content-language" content={inLanguage} />
    <meta name="language" content={inLanguage} />
    <meta name="robots" content={robotsContent} />
    <meta name="geo.region" content="FR-13" />
    <meta name="geo.placename" content="Marseille" />
    <meta name="geo.position" content={`${marseilleLat};${marseilleLng}`} />
    <meta name="ICBM" content={`${marseilleLat}, ${marseilleLng}`} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800;900&family=DM+Sans:wght@400;500&family=Geist+Mono:wght@400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800;900&family=DM+Sans:wght@400;500&family=Geist+Mono:wght@400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800;900&family=DM+Sans:wght@400;500&family=Geist+Mono:wght@400&display=swap"
      />
    </noscript>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Just Dev It Agency" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body class="bg-canvas">
    <div class="grain-overlay" aria-hidden="true"></div>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-full focus:bg-dark focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>
    <slot />
    <script is:inline>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = entry.target.dataset.delay || 0;
              setTimeout(() => {
                entry.target.classList.add('visible');
              }, Number(delay));
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document
        .querySelectorAll('.reveal')
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
