---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Layout/Nav.astro';
import Hero from '../components/Home/Hero.astro';
import SeoIntro from '../components/Home/SeoIntro.astro';
import ScrollShowcase from '../components/Home/ScrollShowcase.astro';
import Services from '../components/Home/Services.astro';
import LeadMagnet from '../components/Home/LeadMagnet.astro';
import Work from '../components/Home/Work.astro';
import Process from '../components/Home/Process.astro';
import Faq from '../components/Home/Faq.astro';
import About from '../components/Home/About.astro';
import Contact from '../components/Home/Contact.astro';
import Footer from '../components/Layout/Footer.astro';
import { t } from '../data/site-strings';

const strings = t('en');
---
<BaseLayout
  lang="en"
  title={strings.seo.title}
  description={strings.seo.description}
  faqItems={strings.faq.items}
  schemaPageType="home"
  breadcrumbTrail={[
    { name: 'Home', path: '/' },
  ]}
>
  <Nav lang="en" />
  <main id="main-content">
    <Hero lang="en" />
    <SeoIntro lang="en" />
    <ScrollShowcase lang="en" />
    <Services lang="en" />
    <LeadMagnet lang="en" />
    <Work lang="en" />
    <Process lang="en" />
    <Faq lang="en" />
    <About lang="en" />
    <Contact lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
