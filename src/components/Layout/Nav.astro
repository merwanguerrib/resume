---
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';
import devLogo from '../../assets/dev-logo.png';

interface Props {
  lang?: Lang;
  altHref?: string;
  sectionBasePath?: string;
  contactHref?: string;
}

const { lang = 'en', altHref, sectionBasePath = '', contactHref } = Astro.props;
const strings = t(lang);
const altLang = lang === 'en' ? 'FR' : 'EN';
const computedAltHref = altHref ?? (lang === 'en' ? '/fr/' : '/');
const sectionPrefix = sectionBasePath || '';
const servicesHref = `${sectionPrefix}#services`;
// Case studies are temporarily hidden; keep this slot pointing to an active section.
const workHref = servicesHref;
const aboutHref = `${sectionPrefix}#about`;
const leadMagnetHref = contactHref ?? `${sectionPrefix}#lead-magnet`;
---

<header class="fixed top-0 left-0 right-0 z-40 flex justify-center pt-5 px-4">
  <nav
    class="flex w-full max-w-2xl items-center rounded-full border border-black/8 bg-surface/90 px-2 py-2 shadow-pill backdrop-blur-md"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a
      href={lang === 'en' ? '/' : '/fr/'}
      class="shrink-0 rounded-full px-3 py-2 transition-colors duration-200 hover:bg-elevated"
      aria-label="Just Dev It Agency home"
    >
      <div class="flex items-center gap-2.5">
        <img
          src={devLogo.src}
          alt=""
          aria-hidden="true"
          class="h-8 w-auto object-contain"
          loading="eager"
          decoding="async"
        />
        <span class="hidden md:inline font-display text-sm font-bold text-muted">
          Just Dev It Agency
        </span>
      </div>
    </a>

    <div class="hidden min-w-0 flex-1 items-center justify-center gap-1 md:flex">
      <!-- Nav links -->
      <a href={servicesHref} class="px-4 py-2 text-sm font-medium text-muted hover:text-ink rounded-full hover:bg-elevated transition-all duration-200 whitespace-nowrap">
        {strings.nav.services}
      </a>
      <a href={workHref} class="px-4 py-2 text-sm font-medium text-muted hover:text-ink rounded-full hover:bg-elevated transition-all duration-200 whitespace-nowrap">
        {strings.nav.work}
      </a>
      <a href={aboutHref} class="px-4 py-2 text-sm font-medium text-muted hover:text-ink rounded-full hover:bg-elevated transition-all duration-200 whitespace-nowrap">
        {strings.nav.about}
      </a>
    </div>

    <div class="ml-auto flex items-center gap-1.5">
      <!-- Lang toggle -->
      <a
        href={computedAltHref}
        class="px-3 py-2 text-xs font-mono font-medium text-muted hover:text-ink rounded-full hover:bg-elevated transition-all duration-200 border border-transparent hover:border-black/8"
      >
        {altLang}
      </a>

      <!-- CTA -->
      <a
        href={leadMagnetHref}
        class="group btn-primary text-sm px-5 py-2.5 whitespace-nowrap shrink-0"
      >
        {strings.nav.contact}
        <span class="btn-icon w-6 h-6">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </nav>
</header>
