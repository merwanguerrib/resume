---
import { Image } from 'astro:assets';
import type { Lang } from '../../data/site-strings';
import { t } from '../../data/site-strings';
import merwanPhoto from '../../assets/merwan-photo.jpg';
import ismaelPhoto from '../../assets/ismael-photo.webp';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const strings = t(lang);
const { about } = strings;
const memberPhotos = {
  merwan: merwanPhoto,
  ismael: ismaelPhoto,
} as const;
---

<section id="about" class="py-section px-4 bg-elevated">
  <div class="mx-auto max-w-6xl">
    <div class="reveal">
      <span class="eyebrow mb-5">{about.eyebrow}</span>
      <h2 class="mt-5 font-display text-display-md font-black text-dark">
        {about.title}
      </h2>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        about.members.map((member, index) => (
          <article class="card-shell reveal h-full" data-delay={String(70 + index * 70)}>
            <div class="card-core flex h-full flex-col overflow-hidden p-0">
              <div class="aspect-[4/5] bg-canvas md:aspect-auto md:h-[min(58vh,520px)]">
                <Image
                  src={memberPhotos[member.id as keyof typeof memberPhotos] ?? merwanPhoto}
                  alt={member.name}
                  class="h-full w-full object-cover object-top md:object-contain"
                  loading="lazy"
                  decoding="async"
                  widths={[380, 520, 760]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  format="webp"
                />
              </div>

              <div class="p-6 md:p-7">
                <h3 class="font-display text-2xl font-bold text-dark">{member.name}</h3>
                <p class="mt-1 text-xs uppercase tracking-[0.14em] text-muted">{member.role}</p>

                <div class="mt-5">
                  {
                    member.bio.split('\n\n').map((paragraph) => (
                      <p class="mb-4 leading-relaxed text-muted last:mb-0">{paragraph}</p>
                    ))
                  }
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
