---
import type { Lang } from '../../data/site-strings';
import type { ServiceSlug } from '../../data/service-pages-data';
import {
  getRelatedServiceSlugs,
  getServicePage,
  getServicePath,
} from '../../data/service-pages-data';

interface Props {
  lang?: Lang;
  slug: ServiceSlug;
}

const { lang = 'en', slug } = Astro.props;
const page = getServicePage(slug);
const relatedSlugs = getRelatedServiceSlugs(slug);
const homePath = lang === 'fr' ? '/fr/' : '/';
const servicesPath = `${homePath}#services`;
const serviceLeadPath = '#service-lead-magnet';
const workPath = `${homePath}#services`;
const formName = 'service-lead-audit';
const formId = `service-lead-form-${slug}-${lang}`;
const successId = `service-lead-success-${slug}-${lang}`;

const contextPlaceholderBySlug = {
  website: {
    en: 'https://your-site.com',
    fr: 'https://votre-site.fr',
  },
  app: {
    en: 'https://app.yourcompany.com',
    fr: 'https://app.votreentreprise.com',
  },
  'ai-automation': {
    en: 'HubSpot + Notion + support inbox',
    fr: 'HubSpot + Notion + inbox support',
  },
  n8n: {
    en: 'Lead form -> CRM -> Slack alert',
    fr: 'Formulaire lead -> CRM -> alerte Slack',
  },
};

const formText =
  lang === 'fr'
    ? {
        title: 'Recevoir l’audit priorisé',
        subtitle:
          '2 champs requis. Réponse sous 24h ouvrées avec la meilleure prochaine action.',
        email: 'Email professionnel',
        context: 'URL ou contexte stack',
        objective: 'Objectif principal (optionnel)',
        objectivePlaceholder:
          'Ex: augmenter les leads qualifiés sans refaire tout le site',
        cta: page.leadMagnetCtaLabel.fr,
        trust: 'Sans spam. Désinscription possible à tout moment.',
        success:
          'Merci, c’est bien reçu. Notre équipe vous répond rapidement avec la suite.',
      }
    : {
        title: 'Get the prioritized audit',
        subtitle:
          '2 required fields. Response in 24 business hours with the best next action.',
        email: 'Work email',
        context: 'URL or stack context',
        objective: 'Primary objective (optional)',
        objectivePlaceholder:
          'Ex: increase qualified leads without a full redesign',
        cta: page.leadMagnetCtaLabel.en,
        trust: 'No spam. Unsubscribe anytime.',
        success:
          'Thanks, received. Our team will reply quickly with the next best move.',
      };
---

<section id="overview" class="px-4 pt-32 pb-section bg-elevated scroll-mt-32">
  <div class="mx-auto max-w-6xl">
    <nav
      aria-label={lang === 'fr' ? 'Fil d’ariane' : 'Breadcrumb'}
      class="mb-6 text-xs font-mono uppercase tracking-widest text-muted"
    >
      <a href={homePath} class="hover:text-dark transition-colors duration-200">
        {lang === 'fr' ? 'Accueil' : 'Home'}
      </a>
      <span class="px-2">/</span>
      <a href={servicesPath} class="hover:text-dark transition-colors duration-200">
        {lang === 'fr' ? 'Services' : 'Services'}
      </a>
      <span class="px-2">/</span>
      <span class="text-dark">{page.label[lang]}</span>
    </nav>

    <div class="card-shell reveal">
      <div class="card-core p-8 md:p-12">
        <span class="eyebrow mb-5">
          {lang === 'fr' ? 'Service dédié' : 'Dedicated service'}
        </span>
        <h1 class="font-display text-display-lg font-black text-dark whitespace-pre-line">
          {page.h1[lang]}
        </h1>
        <p class="mt-5 text-base leading-relaxed text-muted md:text-lg">
          {page.intro[lang]}
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a href={serviceLeadPath} class="group btn-primary text-sm px-6 py-3">
            {lang === 'fr' ? 'Parler du projet' : 'Discuss your project'}
            <span class="btn-icon">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
          <a href={serviceLeadPath} class="btn-ghost text-sm px-6 py-3">
            {page.leadMagnetCtaLabel[lang]}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
      <article id="scope" class="card-shell reveal lg:col-span-2 scroll-mt-32" data-delay="60">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">{page.offerTitle[lang]}</h2>
          <ul class="mt-4 grid gap-2.5">
            {page.offerItems[lang].map((item) => (
              <li class="service-list-item">{item}</li>
            ))}
          </ul>
        </div>
      </article>

      <article class="card-shell reveal" data-delay="120">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">{page.outcomesTitle[lang]}</h2>
          <ul class="mt-4 grid gap-2.5">
            {page.outcomesItems[lang].map((item) => (
              <li class="service-list-item">{item}</li>
            ))}
          </ul>
        </div>
      </article>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
      <article id="process" class="card-shell reveal scroll-mt-32" data-delay="180">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">{page.processTitle[lang]}</h2>
          <ol class="mt-4 grid gap-2.5">
            {page.processSteps[lang].map((item, index) => (
              <li class="service-list-item">
                <span class="font-mono text-xs uppercase tracking-widest text-muted mr-2">
                  {String(index + 1).padStart(2, '0')}
                </span>
                {item}
              </li>
            ))}
          </ol>
        </div>
      </article>

      <article class="card-shell reveal" data-delay="220">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">{page.proofTitle[lang]}</h2>
          <ul class="mt-4 grid gap-2.5">
            {page.proofItems[lang].map((item) => (
              <li class="service-list-item">{item}</li>
            ))}
          </ul>
        </div>
      </article>

      <article class="card-shell reveal" data-delay="260">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">
            {lang === 'fr' ? 'Services liés' : 'Related services'}
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            {lang === 'fr'
              ? 'Renforcez votre delivery avec des services complémentaires.'
              : 'Strengthen delivery with complementary service tracks.'}
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {relatedSlugs.map((relatedSlug) => (
              <a
                href={getServicePath(relatedSlug, lang)}
                class="inline-flex items-center rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-medium text-dark transition-colors duration-200 hover:bg-canvas"
              >
                {getServicePage(relatedSlug).label[lang]}
              </a>
            ))}
          </div>
          <a href={workPath} class="inline-flex mt-6 text-sm font-medium text-muted hover:text-dark transition-colors duration-200">
            {lang === 'fr' ? 'Explorer les services' : 'Explore services'}
          </a>
        </div>
      </article>
    </div>

    <article id="service-lead-magnet" class="mt-4 card-shell reveal scroll-mt-32" data-delay="300">
        <div class="card-core h-full p-6 md:p-8">
          <h2 class="font-display text-2xl font-bold text-dark">{page.leadMagnetTitle[lang]}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">
            {page.leadMagnetSubtitle[lang]}
          </p>
          <h3 class="mt-5 font-display text-lg font-bold text-dark">
            {page.leadMagnetDeliverablesTitle[lang]}
          </h3>
          <ul class="mt-3 grid gap-2.5">
            {page.leadMagnetDeliverables[lang].map((item) => (
              <li class="service-list-item">{item}</li>
            ))}
          </ul>
          <div class="mt-6 rounded-xl border border-black/8 bg-white p-4 md:p-5">
            <h4 class="font-display text-lg font-bold text-dark">{formText.title}</h4>
            <p class="mt-1 text-xs leading-relaxed text-muted">{formText.subtitle}</p>

            <form
              name={formName}
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="mt-4 grid gap-3"
              id={formId}
            >
              <div class="hidden" aria-hidden="true">
                <input name="bot-field" tabindex="-1" autocomplete="off" />
              </div>
              <input type="hidden" name="form-name" value={formName} />
              <input type="hidden" name="service_slug" value={slug} />
              <input type="hidden" name="service_label" value={page.label[lang]} />
              <input type="hidden" name="locale" value={lang} />
              <input type="hidden" name="lead_source" value="service_page" />

              <div class="flex flex-col gap-1.5">
                <label
                  for={`service-email-${slug}-${lang}`}
                  class="text-xs font-medium text-ink uppercase tracking-wide"
                >
                  {formText.email}
                </label>
                <input
                  id={`service-email-${slug}-${lang}`}
                  name="email"
                  type="email"
                  required
                  placeholder="you@company.com"
                  class="w-full rounded-xl border border-black/8 bg-canvas px-4 py-3 text-sm text-ink placeholder:text-muted/50 outline-none focus:border-dark/30 focus:ring-2 focus:ring-dark/8 transition-all duration-200"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label
                  for={`service-context-${slug}-${lang}`}
                  class="text-xs font-medium text-ink uppercase tracking-wide"
                >
                  {formText.context}
                </label>
                <input
                  id={`service-context-${slug}-${lang}`}
                  name="context"
                  type="text"
                  required
                  placeholder={contextPlaceholderBySlug[slug][lang]}
                  class="w-full rounded-xl border border-black/8 bg-canvas px-4 py-3 text-sm text-ink placeholder:text-muted/50 outline-none focus:border-dark/30 focus:ring-2 focus:ring-dark/8 transition-all duration-200"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label
                  for={`service-objective-${slug}-${lang}`}
                  class="text-xs font-medium text-ink uppercase tracking-wide"
                >
                  {formText.objective}
                </label>
                <textarea
                  id={`service-objective-${slug}-${lang}`}
                  name="objective"
                  rows="3"
                  placeholder={formText.objectivePlaceholder}
                  class="w-full rounded-xl border border-black/8 bg-canvas px-4 py-3 text-sm text-ink placeholder:text-muted/50 outline-none focus:border-dark/30 focus:ring-2 focus:ring-dark/8 transition-all duration-200 resize-none"
                ></textarea>
              </div>

              <button type="submit" class="group btn-primary w-full justify-center mt-1 py-3">
                {formText.cta}
                <span class="btn-icon">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
              </button>
            </form>

            <p class="mt-3 text-xs text-muted">{formText.trust}</p>

            <div id={successId} class="hidden mt-4 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
              {formText.success}
            </div>
          </div>

          <div class="mt-5 flex flex-wrap gap-3">
            <a href={workPath} class="btn-ghost text-sm px-6 py-3">
              {lang === 'fr' ? 'Voir les projets livrés' : 'See delivered projects'}
            </a>
            <a href={servicesPath} class="btn-ghost text-sm px-6 py-3">
              {lang === 'fr' ? 'Voir tous les services' : 'See all services'}
            </a>
          </div>
        </div>
    </article>

    <article id="faq" class="mt-4 card-shell reveal scroll-mt-32" data-delay="340">
      <div class="card-core p-6 md:p-8">
        <h2 class="font-display text-2xl font-bold text-dark">{page.faqTitle[lang]}</h2>
        <div class="mt-4 grid gap-3">
          {page.faqItems[lang].map((item) => (
            <details class="faq-item">
              <summary class="faq-question">{item.question}</summary>
              <p class="faq-answer">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </article>

    <article class="mt-4 card-shell reveal" data-delay="380">
      <div class="card-core p-6 md:p-8">
        <h2 class="font-display text-2xl font-bold text-dark">{page.finalCtaTitle[lang]}</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">
          {page.finalCtaBody[lang]}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={serviceLeadPath} class="group btn-primary text-sm px-6 py-3">
            {page.finalCtaPrimary[lang]}
            <span class="btn-icon">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
          <a href={servicesPath} class="btn-ghost text-sm px-6 py-3">
            {page.finalCtaSecondary[lang]}
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .service-list-item {
    position: relative;
    padding-left: 1rem;
    color: #1f1e1b;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .service-list-item::before {
    content: '';
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 9999px;
    background: rgba(12, 12, 10, 0.75);
    box-shadow: 0 0 0 4px rgba(12, 12, 10, 0.08);
  }

  .faq-item {
    border: 1px solid rgba(12, 12, 10, 0.08);
    border-radius: 0.9rem;
    background: #fff;
    padding: 0.8rem 1rem;
  }

  .faq-item[open] {
    border-color: rgba(12, 12, 10, 0.22);
  }

  .faq-question {
    list-style: none;
    cursor: pointer;
    font-size: 0.92rem;
    font-weight: 700;
    color: #1f1e1b;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-answer {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #4f4d46;
  }
</style>

<script define:vars={{ formId, successId }}>
  (() => {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const success = document.getElementById(successId);
    if (!form || !success) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const payload = new FormData(form);
      const params = new URLSearchParams();
      payload.forEach((value, key) => {
        params.append(key, String(value));
      });
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });
        form.classList.add('hidden');
        success.classList.remove('hidden');
      } catch {
        form.submit();
      }
    });
  })();
</script>
